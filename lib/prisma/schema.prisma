datasource db {
  provider = "sqlite"
  url      = "file:./cv.db"
}

generator client {
  provider = "prisma-client-js"
}

model Word {
  id    Int      @id @default(autoincrement())
  uuid  String   @unique
  words String[]
  isFinalized Boolean @default(false)
    @@map("word")
}

model CVData {
  id        Int      @id @default(autoincrement())
  language  String   @unique // 'fr' or 'en'
  data      String   // JSON string containing all CV data for this language
  updatedAt DateTime @default(now()) @updatedAt
    @@map("cv_data")
}
